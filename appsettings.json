{
  "Sqs": {
    "QueueName": "your-sqs-queue-name"
  },
  "Api": {
    "EndpointA": "https://api-a.example.com",
    "EndpointB": "https://api-b.example.com",
    "TimeoutSeconds": 30
  },
  "Retry": {
    "MaxRetries": 3,
    "BaseDelaySeconds": 2
  },
  "Aws": {
    "Region": "us-east-1",
    "SecretsManagerSecretName": "sqs-processor/api-credentials"
  },
  "Serilog": {
    "MinimumLevel": "Information"
  }
}
